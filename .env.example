# Copy this file to `.env` and fill in your keys.
# The backend auto-loads `.env` on startup (see app/server.py::_load_dotenv).
# Never commit `.env` — it's in .gitignore.

# Google Gemini API key — get one for free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the default 100 MB upload ceiling (in MB)
# TRASHPANDA_MAX_UPLOAD_MB=100

# PostgreSQL database URL for the new SaaS persistence layer.
# If unset, the DB helpers build a local dev URL from the TRASHPANDA_DB_* vars.
# TRASHPANDA_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/trashpanda

# Optional local-development PostgreSQL parts used when TRASHPANDA_DATABASE_URL
# is not set.
# TRASHPANDA_DB_HOST=localhost
# TRASHPANDA_DB_PORT=5432
# TRASHPANDA_DB_NAME=trashpanda
# TRASHPANDA_DB_USER=postgres
# TRASHPANDA_DB_PASSWORD=postgres
# TRASHPANDA_DB_ECHO=false
# TRASHPANDA_DB_POOL_SIZE=10
# TRASHPANDA_DB_MAX_OVERFLOW=20
