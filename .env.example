# Copy this file to `.env` and fill in your keys.
# The backend auto-loads `.env` on startup (see app/server.py::_load_dotenv).
# Never commit `.env` — it's in .gitignore.

# Google Gemini API key — get one for free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the default 100 MB upload ceiling (in MB)
# TRASHPANDA_MAX_UPLOAD_MB=100
