# TrashPanda frontend — operator workstation env
#
# Copy this file to ``.env.local`` (which is gitignored) and edit
# the values for your deployment. The frontend reads these at
# server-start time, so restart ``npm run dev`` after editing.
#
# ─── BACKEND URL ──────────────────────────────────────────────────────
# Where the BFF talks to the backend. The recommended setup is to
# run the SSH tunnel (deploy/tunnel.ps1 or deploy/tunnel.sh) so
# localhost:8001 reaches the VPS backend on 127.0.0.1:8000.
#
# Possible values:
#   http://localhost:8001    ← VPS via SSH tunnel  (RECOMMENDED)
#   http://localhost:8000    ← backend running on this laptop
#   (unset)                  ← in-memory mock adapter (no backend)
#
TRASHPANDA_BACKEND_URL=http://localhost:8001

# ─── OPERATOR BEARER TOKEN ────────────────────────────────────────────
# Required when the VPS has TRASHPANDA_OPERATOR_TOKEN set in
# /etc/trashpanda/backend.env. The BFF forwards this header on
# every request to /api/operator/*. Find your token by SSHing
# into the VPS and reading the env file:
#
#   ssh root@<vps_ip> 'cat /etc/trashpanda/backend.env | grep OPERATOR_TOKEN'
#
# Leave unset for local dev where the backend has no auth configured.
#
# TRASHPANDA_OPERATOR_TOKEN=
