# Copy to .env.local for local dev.

# When unset, frontend falls back to /api/mock routes (built-in mock adapter).
# When set to e.g. http://localhost:8000, Next.js proxies /api/backend/* to your FastAPI/Flask backend.
# TRASHPANDA_BACKEND_URL=http://localhost:8000

# Adapter strategy: "mock" (default in dev) | "proxy" (calls /api/backend/*)
NEXT_PUBLIC_TRASHPANDA_ADAPTER=mock
