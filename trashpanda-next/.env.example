# Copy this file to .env.local for local development.
# .env.local is gitignored and never committed.

# ── Mock mode (default) ────────────────────────────────────────────────────
# When TRASHPANDA_BACKEND_URL is NOT set, the frontend uses the built-in
# in-memory mock adapter. Jobs progress automatically through
# queued → running → completed (or failed ~5% of the time).
# No Python process needed.

# ── Proxy mode (real backend) ──────────────────────────────────────────────
# Set this to the URL where your FastAPI/Flask HTTP server is running.
# The Next.js API routes will proxy directly to that service.
#
# Expected backend endpoints:
#   POST   /jobs                              multipart: field "file" → { job_id }
#   GET    /jobs/{job_id}                     → JobResult JSON
#   GET    /jobs/{job_id}/artifacts/{key}     → file download (xlsx / csv)
#
# TRASHPANDA_BACKEND_URL=http://localhost:8000
